{
  "extends": "default",
  "meta": {
    "name": "chouge-agent-common",
    "version": "0.1.0",
    "description": "Shared runtime access for local coding agents"
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow network-outbound (path \"@HOME@/ghq/github.com/nananaman/dotfiles/herdr/herdr.sock\"))"
  ],
  "groups": {
    "include": ["mise_manager"]
  },
  "network": {
    "allow_domain": ["api.github.com"]
  },
  "filesystem": {
    "allow": [
      "$HOME/.agents",
      "$HOME/.claude",
      "$HOME/.codex",
      "$HOME/.pi",
      "$HOME/.local/state/mise",
      "$HOME/go/pkg/mod",
      "$HOME/ghq/github.com/nananaman/dotfiles",
      "$HOME/ghq/github.com/nananaman/skills"
    ],
    "allow_file": ["$HOME/.claude.json", "$HOME/.claude.json.lock", "$HOME/.claude.lock"],
    "bypass_protection": ["$HOME/ghq/github.com/nananaman/dotfiles/zsh/zshrc"],
    "read": [
      "$HOME/.local/share/nono-agent-wrappers",
      "$HOME/ghq/github.com/nananaman/dotfiles/apm"
    ]
  },
  "platform_overrides": {
    "macos": {
      "filesystem": {
        "read": ["$HOME/.vite-plus"],
        "write_file": [
          "$HOME/.vite-plus/cache/resolve_cache.json",
          "$HOME/.vite-plus/js_runtime/node/index_cache.json"
        ]
      }
    }
  },
  "command_policies": {
    "approval_backends": {
      "terminal": {
        "type": "terminal"
      }
    },
    "approval_defaults": {
      "backend": "terminal",
      "timeout_secs": 60
    },
    "credentials": {
      "herdr-socket": {
        "type": "local-socket",
        "path": "$HERDR_SOCKET_PATH",
        "mode": "connect",
        "env_var": "HERDR_SOCKET_PATH"
      }
    },
    "commands": {
      "pi": {
        "from": {
          "session": {
            "sandbox": {
              "unsafe_macos_seatbelt_rules": [
                "(allow process-exec (literal \"@HOME@/.vite-plus/js_runtime/node/24.16.0/lib/node_modules/@earendil-works/pi-coding-agent/dist/cli.js\"))",
                "(allow process-exec (literal \"@HOME@/.vite-plus/0.1.11/bin/vp\"))"
              ]
            },
            "invocation_policy": {
              "default": "approve",
              "allow": [
                {
                  "argv": {
                    "exact": [
                      "--no-session",
                      "--tools",
                      "read,grep,find,ls",
                      "--thinking",
                      "low",
                      "-p"
                    ]
                  }
                },
                {
                  "argv": {
                    "exact": ["--no-session", "--tools", "", "--thinking", "low", "-p"]
                  }
                }
              ]
            }
          }
        }
      },
      "gh": {
        "from": {
          "session": {
            "sandbox": {
              "fs_read": ["$WORKDIR"],
              "fs_read_file": [
                "$HOME/.config/gh/config.yml",
                "$HOME/.config/gh/hosts.yml"
              ],
              "unsafe_macos_seatbelt_rules": [
                "(allow process-exec (literal \"@GH_WRAPPED@\"))",
                "(allow network-outbound (remote tcp \"localhost:*\"))"
              ]
            },
            "invocation_policy": {
              "default": "approve",
              "deny": [
                {
                  "argv": { "prefix": ["auth", "login"] },
                  "reason": "GitHub credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["auth", "logout"] },
                  "reason": "GitHub credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["auth", "refresh"] },
                  "reason": "GitHub credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["auth", "setup-git"] },
                  "reason": "GitHub credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["auth", "switch"] },
                  "reason": "GitHub credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["auth", "token"] },
                  "reason": "GitHub credential reads stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["auth", "git-credential", "store"] },
                  "reason": "GitHub credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["auth", "git-credential", "erase"] },
                  "reason": "GitHub credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["config", "set"] },
                  "reason": "GitHub CLI configuration changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["secret"] },
                  "reason": "GitHub secret changes stay outside agent sessions"
                }
              ],
              "allow": [
                { "argv": { "exact": ["--version"] } },
                { "argv": { "exact": ["auth", "git-credential", "get"] } },
                { "argv": { "exact": ["api", "/rate_limit"] } },
                { "argv": { "prefix": ["api", "repos/nananaman/skills/pulls"] } },
                { "argv": { "prefix": ["repo", "view"] } },
                { "argv": { "prefix": ["pr", "create"] } },
                { "argv": { "prefix": ["pr", "view"] } }
              ]
            }
          }
        }
      },
      "herdr": {
        "from": {
          "session": {
            "sandbox": {
              "fs_read": [
                "/nix/store/fc8v072pz2cqnqh2fyvmjn9b02avixc2-herdr-0.7.5",
                "/nix/store/wjb6smwmv8cynnr776j01kjjzdks1863-libiconv-113"
              ],
              "credentials": ["herdr-socket"],
              "unsafe_macos_seatbelt_rules": [
                "(allow network-outbound (path \"@HOME@/ghq/github.com/nananaman/dotfiles/herdr/herdr.sock\"))"
              ]
            },
            "invocation_policy": {
              "default": "deny",
              "deny": [
                { "argv": { "prefix": ["workspace", "create"] } },
                { "argv": { "prefix": ["workspace", "focus"] } },
                { "argv": { "prefix": ["workspace", "close"] } },
                { "argv": { "prefix": ["tab", "focus"] } },
                { "argv": { "prefix": ["pane", "focus"] } },
                { "argv": { "prefix": ["pane", "send-text"] } },
                { "argv": { "prefix": ["pane", "send-keys"] } },
                { "argv": { "prefix": ["pane", "move"] } },
                { "argv": { "prefix": ["pane", "swap"] } },
                { "argv": { "prefix": ["pane", "resize"] } },
                { "argv": { "prefix": ["pane", "zoom"] } },
                { "argv": { "prefix": ["pane", "run"] } },
                { "argv": { "prefix": ["pane", "close"] } },
                { "argv": { "prefix": ["agent", "focus"] } },
                { "argv": { "prefix": ["agent", "attach"] } },
                { "argv": { "prefix": ["agent", "send"] } },
                { "argv": { "contains": ["--focus"] } }
              ],
              "approve": [
                { "argv": { "prefix": ["workspace", "rename"] } },
                { "argv": { "prefix": ["tab", "rename"] } },
                { "argv": { "prefix": ["pane", "rename"] } }
              ],
              "allow": [
                { "argv": { "exact": [] } },
                { "argv": { "exact": ["--help"] } },
                { "argv": { "exact": ["--version"] } },
                { "argv": { "prefix": ["status"] } },
                { "argv": { "prefix": ["workspace", "list"] } },
                { "argv": { "prefix": ["workspace", "get"] } },
                { "argv": { "prefix": ["tab", "list"] } },
                { "argv": { "prefix": ["tab", "get"] } },
                { "argv": { "prefix": ["tab", "create"] } },
                { "argv": { "prefix": ["tab", "close"] } },
                { "argv": { "prefix": ["pane", "list"] } },
                { "argv": { "prefix": ["pane", "current"] } },
                { "argv": { "prefix": ["pane", "get"] } },
                { "argv": { "prefix": ["pane", "read"] } },
                { "argv": { "prefix": ["pane", "layout"] } },
                { "argv": { "prefix": ["pane", "process-info"] } },
                { "argv": { "prefix": ["pane", "neighbor"] } },
                { "argv": { "prefix": ["pane", "edges"] } },
                { "argv": { "prefix": ["agent", "list"] } },
                { "argv": { "prefix": ["agent", "get"] } },
                { "argv": { "prefix": ["agent", "read"] } },
                { "argv": { "prefix": ["agent", "start"] } },
                { "argv": { "prefix": ["agent", "wait"] } },
                { "argv": { "prefix": ["agent", "prompt"] } },
                { "argv": { "prefix": ["wait", "output"] } },
                { "argv": { "prefix": ["wait", "agent-status"] } },
                { "argv": { "contains": ["--no-focus"] } }
              ]
            }
          }
        }
      },
      "container": {
        "executable": "/opt/homebrew/opt/container/libexec/container",
        "from": {
          "session": {
            "sandbox": {
              "fs_read": [
                "/opt/homebrew/opt/container",
                "$WORKDIR",
                "$HOME/Library/Application Support/com.apple.container"
              ],
              "fs_read_file": ["/bin/launchctl"],
              "fs_write": ["$WORKDIR", "$HOME/Library/Application Support/com.apple.container"],
              "environment": {
                "set_vars": {
                  "CONTAINER_INSTALL_ROOT": "/opt/homebrew/opt/container"
                }
              },
              "unsafe_macos_seatbelt_rules": ["(allow process-exec (literal \"/bin/launchctl\"))"]
            },
            "invocation_policy": {
              "default": "approve",
              "deny": [
                {
                  "argv": { "prefix": ["registry", "login"] },
                  "reason": "registry credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["registry", "logout"] },
                  "reason": "registry credential changes stay outside agent sessions"
                },
                {
                  "argv": { "prefix": ["system", "dns", "create"] },
                  "reason": "host DNS and packet-filter changes are not delegated to agents"
                },
                {
                  "argv": { "prefix": ["system", "dns", "delete"] },
                  "reason": "host DNS and packet-filter changes are not delegated to agents"
                },
                {
                  "argv": { "prefix": ["system", "kernel", "set"] },
                  "reason": "system kernel changes are not delegated to agents"
                }
              ],
              "allow": [
                { "argv": { "exact": [] } },
                { "argv": { "exact": ["--help"] } },
                { "argv": { "exact": ["--version"] } },
                { "argv": { "prefix": ["list"] } },
                { "argv": { "prefix": ["inspect"] } },
                { "argv": { "prefix": ["logs"] } },
                { "argv": { "prefix": ["stats"] } },
                { "argv": { "prefix": ["builder", "status"] } },
                { "argv": { "prefix": ["image", "list"] } },
                { "argv": { "prefix": ["image", "inspect"] } },
                { "argv": { "prefix": ["registry", "list"] } },
                { "argv": { "prefix": ["network", "list"] } },
                { "argv": { "prefix": ["network", "inspect"] } },
                { "argv": { "prefix": ["volume", "list"] } },
                { "argv": { "prefix": ["volume", "inspect"] } },
                { "argv": { "prefix": ["machine", "list"] } },
                { "argv": { "prefix": ["machine", "inspect"] } },
                { "argv": { "prefix": ["machine", "logs"] } },
                { "argv": { "prefix": ["system", "version"] } },
                { "argv": { "prefix": ["system", "df"] } },
                { "argv": { "prefix": ["system", "property", "list"] } },
                { "argv": { "prefix": ["system", "dns", "list"] } }
              ]
            }
          }
        }
      }
    }
  }
}

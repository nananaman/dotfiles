{
  "extends": ["chouge-agent-common", "codex"],
  "meta": {
    "name": "chouge-codex",
    "version": "0.1.0",
    "description": "Local Codex profile"
  },
  "command_policies": {
    "approval_backends": {
      "terminal": {
        "type": "terminal"
      }
    },
    "approval_defaults": {
      "backend": "terminal",
      "timeout_secs": 60
    },
    "commands": {
      "pi": {
        "executable": "/Users/juntawatanabe/.local/share/nono-agent-wrappers/pi",
        "from": {
          "session": {
            "sandbox": {
              "unsafe_macos_seatbelt_rules": [
                "(allow process-exec (literal \"/Users/juntawatanabe/.vite-plus/js_runtime/node/24.16.0/lib/node_modules/@earendil-works/pi-coding-agent/dist/cli.js\"))",
                "(allow process-exec (literal \"/Users/juntawatanabe/.vite-plus/0.1.11/bin/vp\"))"
              ]
            },
            "invocation_policy": {
              "default": "approve",
              "allow": [
                {
                  "argv": {
                    "exact": [
                      "--no-session",
                      "--tools",
                      "read,grep,find,ls",
                      "--thinking",
                      "low",
                      "-p"
                    ]
                  }
                },
                {
                  "argv": {
                    "exact": [
                      "--no-session",
                      "--tools",
                      "",
                      "--thinking",
                      "low",
                      "-p"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
